{
  "name": "agent-assurance",
  "version": "0.1.0",
  "description": "AAL Core — framework-neutral red-team engine for AI agents (toxic-flow graph, side-effect detection, SARIF). Part of the Agent Assurance Layer.",
  "type": "module",
  "license": "MIT",
  "bin": { "aal": "./dist/cli.js" },
  "exports": { ".": "./src/index.ts" },
  "engines": { "node": ">=22.18" },
  "scripts": {
    "check": "bun run lint && bun run tsc && bun run test",
    "lint": "oxlint",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "cli": "bun run src/cli.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "neverthrow": "^8.2.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@dotenvx/dotenvx": "^1.67.0",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
