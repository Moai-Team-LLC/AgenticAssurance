# AAL Core runtime configuration (inject via dotenvx; never commit real values)
# LLM provider used only as the pluggable oracle for attack success conditions (Step 4).
# AAL Core imports NO AgenticMind code — this is a generic provider, not the engine's judge.
AAL_ORACLE_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Default number of stability runs per dynamic attack (Step 4).
AAL_STABILITY_RUNS=5
